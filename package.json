{
  "name": "my-balance-expo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "add-format": "git add -u",
    "build:dev": "eas build --profile development",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:preview": "eas build --profile preview",
    "build:production": "eas build --profile production",
    "dev:install": "eas build --profile development --platform ios && eas device:create"
  },
  "dependencies": {
    "@expo/ui": "~55.0.6",
    "@expo/vector-icons": "^15.0.3",
    "@infinitered/react-native-mlkit-text-recognition": "^5.0.1",
    "@react-google-maps/api": "^2.20.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@rnmapbox/maps": "^10.2.10",
    "@tanstack/query-async-storage-persister": "^5.90.22",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "expo": "^55.0.0",
    "expo-auth-session": "~55.0.10",
    "expo-blur": "~55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "~55.0.19",
    "expo-device": "~55.0.10",
    "expo-document-picker": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.14",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.9",
    "expo-notifications": "~55.0.14",
    "expo-pdf-text-extract": "^1.0.1",
    "expo-router": "~55.0.8",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.11",
    "expo-web-browser": "~55.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-google-places-sdk": "^0.4.0",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "pre-commit": "^1.2.2",
    "prettier": "^3.5.3",
    "typescript": "~5.9.2"
  },
  "pre-commit": [
    "format",
    "add-format"
  ],
  "private": true
}
